# .env
# данный файл подготовлен для разработки через docker
SECRET_KEY=your_secret_keys

# расположение сервера (локальная сеть/интернет)
SERVER_LOCATION=private
#                └── private - сервер расположен в доверенной сети
#                └── public - сервер расположен в публичной сети

# подключение к БД

# нужно для сборки внешней БД  POSTGRES из переменных
# Допустимые значения: 1, True, true, yes, y, on
EXT_DATABASE=True  

# настройка POSTGRES (идет до подключения к БД)
POSTGRES_PASSWORD=password
POSTGRES_USER=user
POSTGRES_DB=task_manager

# нужно для запуска сервера при разработке в режиме отладки (раскомментировать)
# Допустимые значения: 1, True, true, yes, y, on
DEBUG=True

# Настройка сервера кэширования (Memcached) - стандартные порты
CACHE_URL=memcache://127.0.0.1:11211,127.0.0.1:11212,127.0.0.1:11213

