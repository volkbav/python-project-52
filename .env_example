# .env
SECRET_KEY=your_secret_keys

# --- настройка POSTGRES (идет до подключения к БД) ---

POSTGRES_PASSWORD=password
POSTGRES_USER=user
POSTGRES_DB=task_manager

# ------

# подключение к БД (необходимо раскомментировать следующую строку)

# нужно для сборки подключения БД из переменных выше
# Допустимые значения: 1, True, true, yes, y, on
EXT_DATABASE=True  


# нужно для запуска сервера при разработке в режиме отладки (раскомментировать)
# Допустимые значения: 1, True, true, yes, y, on
# DEBUG=True

# Настройка сервера кэширования (Memcached) - стандартные порты
CACHE_URL=memcache://127.0.0.1:11211,127.0.0.1:11212,127.0.0.1:11213

# подключение Rollbar -  трекинг ошибок
ROLLBAR_ACCESS_TOKEN=your_secret_keys_from_rollbar
ROLLBAR_ENV=development  # окружение
#               └── development - разработка
#               └── staging / test — тестовый сервер
#               └── production — deploy

# расположение сервера (локальная сеть/интернет)
SERVER_LOCATION=local
#                └── local - сервер расположен в локальной сети
#                └── internet - сервер расположен в интернете

# адрес сайта в интернет
# !ВАЖНО! писать без пробелов и http(s)
ALLOWED_HOSTS=example.com,www.example.com
